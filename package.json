{
  "name": "mikro-orm-koa-ts-example",
  "version": "0.0.1",
  "description": "Example integration of MikroORM into Koa (in typescript)",
  "author": "Martin Adamek",
  "license": "MIT",
  "scripts": {
    "start": "tsc && node dist/server",
    "start:dev": "tsx watch app/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "renovate": {
    "extends": [
      "config:base",
      ":preserveSemverRanges",
      ":semanticCommitTypeAll(chore)"
    ],
    "semanticCommits": "enabled",
    "separateMajorMinor": false,
    "dependencyDashboard": false,
    "packageRules": [
      {
        "matchUpdateTypes": [
          "patch",
          "minor"
        ],
        "groupName": "patch/minor dependencies",
        "groupSlug": "all-non-major",
        "automerge": true,
        "automergeType": "branch"
      }
    ],
    "schedule": [
      "every weekday"
    ]
  },
  "engines": {
    "node": ">= 22.17.0"
  },
  "dependencies": {
    "@mikro-orm/core": "^7.0.6",
    "@mikro-orm/decorators": "^7.0.6",
    "@mikro-orm/sql-highlighter": "^1.0.1",
    "@mikro-orm/sqlite": "^7.0.6",
    "koa": "^3.0.0",
    "koa-body": "^7.0.0",
    "koa-router": "^14.0.0",
    "typescript": "6.0.3",
    "zod": "^4.0.0"
  },
  "packageManager": "yarn@4.14.1",
  "devDependencies": {
    "@mikro-orm/cli": "^7.0.6",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.3",
    "@types/koa": "^3.0.0",
    "@types/koa-router": "^7.4.8",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "reflect-metadata": "^0.2.2",
    "supertest": "^7.0.0",
    "tsx": "^4.0.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.0"
  },
  "mikro-orm": {
    "configPaths": [
      "./app/mikro-orm.config.ts",
      "./dist/mikro-orm.config.js"
    ]
  }
}
